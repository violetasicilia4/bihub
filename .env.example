# VITE_SUPABASE_URL: URL de tu proyecto Supabase (Project Settings > API > Project URL).
VITE_SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"

# VITE_SUPABASE_ANON_KEY: clave pública "anon" del proyecto (Project Settings > API > anon public).
# Es segura para exponer en el frontend: los permisos reales los define Row Level Security (RLS)
# en la base de datos (ver supabase/schema.sql).
VITE_SUPABASE_ANON_KEY="tu-anon-key"
